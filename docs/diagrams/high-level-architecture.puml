@startuml
title System Architecture — Component Diagram

left to right direction

package "Client" {
  [React UI]
}

package "API Client" {
  [src/api/client]
}

package "Service Layer" {
  [src/api/service]

  package "Modules" {
    [Policy Parser] <<src/api/policyParser/*>>
    [Journal Renderer] <<src/api/journalRenderer.ts>>
    [Journey Resolver]
    [Instruction Templates]
    [Research Consents]
    [Patient Journeys]
  }
}

package "Persistence" {
  [In-memory store]
  [localStorage]
}

[React UI] --> [src/api/client]
[src/api/client] --> [src/api/service]
[src/api/service] --> [Policy Parser]
[src/api/service] --> [Journal Renderer]
[src/api/service] --> [Journey Resolver]
[src/api/service] --> [Instruction Templates]
[src/api/service] --> [Research Consents]
[src/api/service] --> [Patient Journeys]
[src/api/service] --> [In-memory store]
[In-memory store] --> [localStorage]

note bottom of [Journey Resolver]
  Computes effective steps,
  hydrates instructions,
  handles template derivation
  and phase-aware scheduling,
  pause-shift calculation,
  getMergedDueStepsForPatient
end note

note bottom of [Research Consents]
  grantConsent (idempotent),
  revokeConsent, hasActiveConsent,
  audit trail via revokedAt
end note

note bottom of [Patient Journeys]
  assignPatientJourney,
  pauseJourney, resumeJourney,
  modifyPatientJourney,
  cancelJourney,
  totalPausedDays accumulation
end note

@enduml
