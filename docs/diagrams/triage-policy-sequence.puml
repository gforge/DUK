@startuml
title Triage → Policy Evaluation — Sequence

actor Clinician
participant "UI" as UI
participant "Client" as Client
participant "Service" as Service
participant "JourneyResolver" as JR
participant "PolicyParser" as PP

Clinician -> UI : submit triage form
UI -> Client : triageCase(request)
Client -> Service : triageCase
Service -> Service : gather latest FormResponses
Service -> JR : buildPolicyScopeWithAliases(responses)
JR -> PP : evaluateExpression(rule, scope)
PP --> JR : evaluation result
JR --> Service : PolicyWarning[]
Service -> Client : updated Case with policyWarnings
Service -> Service : addAuditEvent

note right of PP: src/api/policyParser/*

@enduml
