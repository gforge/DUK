@startuml
title Score Aliasing — Sequence

actor System
participant "JourneyTemplateEntry" as Entry
participant "Service" as Service
participant "PolicyScope" as Scope

System -> Entry : read scoreAliases\n{ alias: "OSS.total"\n-> path: "scores.OSS.total" }
Service -> Scope : inject alias values\ninto numeric scope
Scope --> Service : scope {OSS.total: 22}
Service -> PolicyParser : evaluateExpression(rule, scope)

note right
  Aliasing implemented in
  journeyResolver
  .buildPolicyScopeWithAliases
end note

@enduml
