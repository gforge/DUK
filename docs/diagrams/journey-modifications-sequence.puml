@startuml
' Purpose: Journey modification operations and audit trail
' Source of truth:
'   src/api/service/patientJourneys.ts
'   src/api/service/journeyResolver.ts

title Journey Modifications - Sequence Diagram

actor Clinician
participant "ModifyJourneyDialog\n(UI)" as UI
participant "client/patientJourneys" as Client
participant "service/patientJourneys" as Service
participant "patchStore" as Store

Clinician -> UI : Open modification dialog

alt ADD_STEP
  Clinician -> UI : Submit ADD_STEP(reason, entry)
  UI -> Client : modifyPatientJourney(journeyId, ADD_STEP, payload)
  Client -> Service : modifyPatientJourney(...)
  Service -> Store : Append JourneyModification(type=ADD_STEP)\nand add entry to journey modifications/effective plan
  Store --> Service : updated journey
  Service --> Client : updated journey
  Client --> UI : success
else REMOVE_STEP
  Clinician -> UI : Submit REMOVE_STEP(reason, stepId)
  UI -> Client : modifyPatientJourney(journeyId, REMOVE_STEP, payload)
  Client -> Service : modifyPatientJourney(...)
  Service -> Store : Append JourneyModification(type=REMOVE_STEP)
  Store --> Service : updated journey
  Service --> Client : updated journey
  Client --> UI : success
else CANCEL
  Clinician -> UI : Submit CANCEL(reason)
  UI -> Client : cancelJourney(journeyId, reason, userId)
  Client -> Service : cancelJourney(...)
  Service -> Store : If data exists: append JourneyModification(type=CANCEL)\nset status COMPLETED; else delete journey
  Store --> Service : cancel result
  Service --> Client : cancel result
  Client --> UI : success
end

note right of Service
  All modification types require
  a clinician reason and are kept
  as audit-friendly history in
  PatientJourney.modifications[].
end note

@enduml